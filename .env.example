# Database (SQLite para dev, PostgreSQL para prod)
DATABASE_URL=sqlite+aiosqlite:///./monarch_ai.db

# Comportamento dos agentes
MAX_AGENT_RETRIES=3
APPROVAL_TIMEOUT_MINUTES=60
CONFIDENCE_THRESHOLD=0.70
